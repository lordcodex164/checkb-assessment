            "description": "grpcurl equivalent:\n\ngrpcurl -plaintext -d '{\"userId\":\"<USER_ID>\",\"amount\":200}' \\\n  -proto packages/proto/wallet.proto \\\n  localhost:5002 wallet.WalletService/DebitWallet"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "userId",
      "value": "replace-with-actual-user-id",
      "description": "UUID returned from CreateUser"
    }
  ]
}
