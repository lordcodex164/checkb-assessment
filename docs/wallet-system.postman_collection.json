{
  "info": {
    "name": "Wallet System — gRPC via grpcurl",
    "description": "All requests use grpcurl to talk directly to the gRPC microservices.\n\nPrerequisites:\n  brew install grpcurl   (macOS)\n  or: https://github.com/fullstorydev/grpcurl#installation\n\nProto files live in: packages/proto/",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "User Service",
      "item": [
        {
          "name": "CreateUser",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"name\": \"John Doe\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "grpc://localhost:5001/user.UserService/CreateUser",
              "protocol": "grpc",
              "host": ["localhost"],
              "port": "5001",
              "path": ["user.UserService", "CreateUser"]
            },
            "description": "grpcurl equivalent:\n\ngrpcurl -plaintext -d '{\"email\":\"john.doe@example.com\",\"name\":\"John Doe\"}' \\\n  -proto packages/proto/user.proto \\\n  localhost:5001 user.UserService/CreateUser"
          }
        },
        {
          "name": "GetUserById",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{userId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "grpc://localhost:5001/user.UserService/GetUserById",
              "protocol": "grpc",
              "host": ["localhost"],
              "port": "5001",
              "path": ["user.UserService", "GetUserById"]
            },
            "description": "grpcurl equivalent:\n\ngrpcurl -plaintext -d '{\"id\":\"<USER_ID>\"}' \\\n  -proto packages/proto/user.proto \\\n  localhost:5001 user.UserService/GetUserById"
          }
        }
      ]
    },
    {
      "name": "Wallet Service",
