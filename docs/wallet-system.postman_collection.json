              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "grpc://localhost:5002/wallet.WalletService/CreateWallet",
              "protocol": "grpc",
              "host": ["localhost"],
              "port": "5002",
              "path": ["wallet.WalletService", "CreateWallet"]
            },
            "description": "grpcurl equivalent:\n\ngrpcurl -plaintext -d '{\"userId\":\"<USER_ID>\"}' \\\n  -proto packages/proto/wallet.proto \\\n  localhost:5002 wallet.WalletService/CreateWallet"
          }
        },
        {
          "name": "GetWallet",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "grpc://localhost:5002/wallet.WalletService/GetWallet",
              "protocol": "grpc",
              "host": ["localhost"],
              "port": "5002",
              "path": ["wallet.WalletService", "GetWallet"]
            },
            "description": "grpcurl equivalent:\n\ngrpcurl -plaintext -d '{\"userId\":\"<USER_ID>\"}' \\\n  -proto packages/proto/wallet.proto \\\n  localhost:5002 wallet.WalletService/GetWallet"
          }
        },
        {
          "name": "CreditWallet",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"amount\": 500.00\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "grpc://localhost:5002/wallet.WalletService/CreditWallet",
              "protocol": "grpc",
              "host": ["localhost"],
              "port": "5002",
              "path": ["wallet.WalletService", "CreditWallet"]
            },
            "description": "grpcurl equivalent:\n\ngrpcurl -plaintext -d '{\"userId\":\"<USER_ID>\",\"amount\":500}' \\\n  -proto packages/proto/wallet.proto \\\n  localhost:5002 wallet.WalletService/CreditWallet"
          }
        },
        {
          "name": "DebitWallet",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"amount\": 200.00\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "grpc://localhost:5002/wallet.WalletService/DebitWallet",
              "protocol": "grpc",
