{
  "name": "backend-assessment",
  "version": "1.0.0",
  "description": "Microservice-based Wallet System using NestJS, gRPC, Prisma, and PostgreSQL",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start:api": "cd apps/api-gateway && npm run start:dev",
    "start:user": "cd apps/user-service && npm run start:dev",
    "start:wallet": "cd apps/wallet-service && npm run start:dev",
    "build:user": "cd apps/user-service && npm run build",
    "build:wallet": "cd apps/wallet-service && npm run build",
    "prisma:generate": "cd packages/prisma && npx prisma generate",
    "postinstall": "cd packages/prisma && npx prisma generate",
    "prisma:migrate": "cd packages/prisma && npx prisma migrate dev",
    "prisma:reset": "cd packages/prisma && npx prisma migrate reset",
    "prisma:studio": "cd packages/prisma && npx prisma studio",
    "prisma:pull": "cd packages/prisma && npx prisma db pull",
    "install:all": "npm install && cd apps/user-service && npm install && cd ../../apps/wallet-service && npm install"
  },
  "keywords": [
    "nestjs",
    "grpc",
    "prisma",
    "microservices",
    "wallet"
  ],
  "author": "",
  "license": "MIT",
  "prisma": {
    "schema": "packages/prisma/schema.prisma"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.4.22",
    "@nestjs/microservices": "^10.4.22",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.1",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.20.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "prisma": "^7.6.0"
  }
}
